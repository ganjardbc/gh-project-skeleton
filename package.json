{
  "name": "gh-project-skeleton",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "turbo format",
    "preview": "turbo preview",
    "typecheck": "turbo typecheck",
    "new-module": "npx hygen module new",
    "db:migrate": "pnpm --filter gh-skeleton-api db:migrate",
    "db:seed": "pnpm --filter gh-skeleton-api db:seed",
    "db:studio": "pnpm --filter gh-skeleton-api db:studio",
    "db:generate": "pnpm --filter gh-skeleton-api db:generate"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  }
}