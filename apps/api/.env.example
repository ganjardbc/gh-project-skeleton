# =========================================
# UMKM-POS API - Environment Configuration
# =========================================
# Copy this file to .env and update with your actual values

# =========================================
# DATABASE CONFIGURATION
# =========================================
# MySQL Database Connection
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@localhost:3306/db_project_skeleton"

# =========================================
# APPLICATION CONFIGURATION
# =========================================
# Server Port
PORT=3000

# Node Environment (development | production | test)
NODE_ENV=development

# =========================================
# JWT AUTHENTICATION
# =========================================
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string for production
JWT_SECRET="your_jwt_secret_here"

# JWT Token Expiration (e.g., 1h, 7d, 30d)
JWT_EXPIRES_IN="7d"

# =========================================
# API CONFIGURATION
# =========================================
# API Prefix (e.g., /api/v1)
API_PREFIX="api"

# API Version
API_VERSION="v1"

# =========================================
# CORS CONFIGURATION
# =========================================
# Allowed Origins (comma-separated for multiple origins)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# =========================================
# LOGGING
# =========================================
# Log Level (error | warn | info | debug)
LOG_LEVEL="debug"

# =========================================
# RATE LIMITING (Optional - for production)
# =========================================
# Time to live in seconds
# RATE_LIMIT_TTL=60
# Maximum requests per TTL
# RATE_LIMIT_MAX=100

# =========================================
# S3 / FILE UPLOAD CONFIGURATION
# =========================================
# AWS S3 (or S3-compatible) configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
S3_BUCKET_NAME="umkm-pos-uploads"
# Optional: custom S3 endpoint for compatible services (MinIO, DigitalOcean Spaces, etc.)
# S3_ENDPOINT="https://sgp1.digitaloceanspaces.com"

# Maximum file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Comma-separated list of allowed MIME types
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,application/pdf"

# Signed URL expiration time in seconds (default: 900 = 15 minutes)
SIGNED_URL_EXPIRY=900

# Storage driver (s3 or local)
# "s3" or "local" for local file storage (not recommended for production)
STORAGE_DRIVER="s3"
